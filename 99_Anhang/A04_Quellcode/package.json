{
  "name": "shiftplanner",
  "version": "1.0.0",
  "description": "Generate shift schema JSON from Excel export",
  "main": "src/cli.js",
  "bin": {
    "shift-generator": "src/cli.js",
    "shiftplanner": "src/cli.js"
  },
  "scripts": {
    "cli": "node src/cli.js",
    "build": "pkg .",
    "test": "mkdir -p test/reports && ./test/bats/bin/bats --report-formatter junit -o test/reports -p -T test/FA0*.bats",
    "ci": "mkdir -p test/reports && ./test/bats/bin/bats --report-formatter junit -o test/reports -T test/FA0*.bats"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/isaaclins/individuelle-praktische-arbeit.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "packageManager": "pnpm@10.30.3",
  "pkg": {
    "targets": [
      "node18-linux-x64",
      "node18-linux-arm64",
      "node18-macos-x64",
      "node18-macos-arm64",
      "node18-win-x64",
      "node18-win-arm64"
    ],
    "outputPath": "dist"
  },
  "bugs": {
    "url": "https://github.com/isaaclins/individuelle-praktische-arbeit/issues"
  },
  "homepage": "https://github.com/isaaclins/individuelle-praktische-arbeit#readme",
  "dependencies": {
    "exceljs": "^4.4.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
